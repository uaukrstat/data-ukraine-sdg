            "constraints": {
              "enum": [
                "urban",
                "rural",
                ""
              ]
            },
            "title": "Type of residence"
          },
          {
            "name": "Decile groups",
            "type": "string",
            "constraints": {
              "enum": [
                "1st group (low income)",
                "2nd group",
                "3rd group",
                "4th group",
                "5th group",
                "6th group",
                "7th group",
                "8th group",
                "9th group",
                "10th group (high income)",
                ""
              ]
            },
            "title": "Decile groups of income"
          },
          {
            "name": "Households",
            "type": "string",
            "constraints": {
              "enum": [
                "households/families with children",
                "households/families without children",
                ""
              ]
            },
            "title": "Household type"
          },
          {
            "name": "Value",
            "type": "number",
            "title": "Value"
          }
        ]
      }
    }
  ],
  "profile": "data-package",
  "name": "1-3-3",
  "title": "Share of food expenditures in total household expenditures, percent"
}